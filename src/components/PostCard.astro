---
export interface Props {
  post: {
    id: string;
    data: {
      title: string;
      description?: string;
      tags?: string[];
      image?: string;
      externalLink?: string;
    };
  };
}

const { post } = Astro.props;
const postUrl = post.data.externalLink || `/${post.id}/`;
const isExternal = !!post.data.externalLink;
---

<article class="post on-list">
  <h2 class="post-title">
    <a href={postUrl} target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener" : undefined}>
      {post.data.title}
    </a>
  </h2>
{post.data.tags && post.data.tags.length > 0 && (
    <span class="post-tags">
      {post.data.tags.map((tag) => (
        <>
          <a href={`/tags/${tag}/`}>{tag}</a>
        </>
      ))}
    </span>
  )}
  {post.data.image && (
    <figure class="post-cover">
      <img src={post.data.image} alt={post.data.title} />
    </figure>
  )}
  {post.data.description && (
    <div class="post-content">
      <p>{post.data.description}</p>
    </div>
  )}
  <div>
    <a href={postUrl} class="read-more button inline" target={isExternal ? "_blank" : undefined} rel={isExternal ? "noopener" : undefined} aria-label={`Read more about ${post.data.title}`}>
      [Read more]
    </a>
  </div>
</article>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { buildPerson } from '../data/person';

const POSTS_PER_PAGE = 10;
const allPosts = (await getCollection('posts'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const currentPage = 1;
const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const siteURL = Astro.site!.href;
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${siteURL}#website`,
    name: 'Diego Castillo',
    url: siteURL,
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    ...buildPerson({ siteURL }),
  },
];
---

<BaseLayout title="Software Engineering Blog" description="Blog by Diego Castillo - software engineer at Buffer exploring systems programming and building products." jsonLd={jsonLd}>
  <h1 class="sr-only">Software Engineering Blog</h1>
  <section class="bio">
    <p>
      Building products at <a target="_blank" rel="noopener" href="https://buffer.com/">Buffer</a>. Playing jazz <a target="_blank" rel="noopener" href="https://www.youtube.com/diegocasmo">@diegocasmo</a>. <a href="/about/">More about me</a>.
    </p>
  </section>

  <div class="posts">
    {posts.map((post) => <PostCard post={post} />)}
  </div>

  {totalPages > 1 && (
    <div class="pagination">
      <div class="pagination__buttons">
        {currentPage < totalPages && (
          <a href="/page/2/" class="button inline next">
            [<span class="button__text">Older posts</span>] &gt;
          </a>
        )}
      </div>
    </div>
  )}
</BaseLayout>

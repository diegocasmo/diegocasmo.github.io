---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildPerson } from '../data/person';

const siteURL = Astro.site!.href;
const description =
  'Diego Castillo is a senior software engineer at Buffer working in TypeScript, Elixir, and Ruby, focused on craftsmanship and simple, thoughtful products.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: new URL('/about/', Astro.site).href,
  mainEntity: buildPerson({ siteURL, description }),
};
---

<BaseLayout title="About" description={description} jsonLd={jsonLd}>
  <div class="page">
    <h1>About</h1>

    <p>
      I'm Diego Castillo, a software engineer. I focus on craftsmanship and
      simple, thoughtful products.
    </p>

    <p>
      These days I work at <a href="https://buffer.com/" target="_blank" rel="noopener">Buffer</a>, a fully
      remote team building social media tools for creators and small businesses.
      Most of my time goes to the parts developers and agents build on top of. I
      write mostly in TypeScript, Elixir, and Ruby.
    </p>

    <p>
      On the side I build my own things. <a href="https://www.tonebuilder.ai/" target="_blank" rel="noopener">ToneBuilder</a> and <a href="https://www.findmomentum.xyz/" target="_blank" rel="noopener">Momentum</a> are
      live, and there are a few more on the <a href="/products/">products</a> page. I also
      play jazz as <a href="https://www.youtube.com/diegocasmo" target="_blank" rel="noopener">@diegocasmo</a>.
      Spanish is my first language, English my second.
    </p>

    <p>
      This blog is where I think out loud about software, building with AI, and
      the occasional CS rabbit hole.
    </p>

    <p>
      Want the full history? It's in my <a href="/resume.pdf">resume</a> and on <a href="https://www.linkedin.com/in/diegocasmo/" target="_blank" rel="noopener">LinkedIn</a>. You
      can also find me on <a href="https://github.com/diegocasmo" target="_blank" rel="noopener">GitHub</a> and <a href="https://x.com/diegocasmo" target="_blank" rel="noopener">X</a>.
    </p>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
  }
  .page p {
    margin-bottom: 1.2em;
  }
</style>

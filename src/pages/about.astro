---
import BaseLayout from '../layouts/BaseLayout.astro';

const siteURL = Astro.site!.href;
const description =
  'Diego Castillo is a senior software engineer at Buffer working in TypeScript, Elixir, and Ruby, focused on craftsmanship and simple, thoughtful products.';

const person = {
  '@type': 'Person',
  '@id': `${siteURL}#person`,
  name: 'Diego Castillo',
  url: siteURL,
  description,
  jobTitle: 'Senior Software Engineer',
  worksFor: { '@type': 'Organization', name: 'Buffer', url: 'https://buffer.com/' },
  alumniOf: [
    { '@type': 'CollegeOrUniversity', name: 'Uppsala University' },
    { '@type': 'CollegeOrUniversity', name: 'Harding University' },
  ],
  knowsAbout: [
    'Software Engineering',
    'Systems Programming',
    'TypeScript',
    'Elixir',
    'Ruby',
    'Computer Science',
  ],
  sameAs: [
    'https://github.com/diegocasmo',
    'https://www.linkedin.com/in/diegocasmo/',
    'https://x.com/diegocasmo',
  ],
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  url: new URL('/about/', Astro.site).href,
  mainEntity: person,
};
---

<BaseLayout title="About" description={description} jsonLd={jsonLd}>
  <div class="page">
    <h1>About</h1>

    <p>
      I'm Diego Castillo, a software engineer. I architect software focused on
      craftsmanship and simple, thoughtful products.
    </p>

    <p>
      I'm a Senior Software Engineer at
      <a href="https://buffer.com/" target="_blank" rel="noopener">Buffer</a>, an
      async-first remote company that builds tools for creators and small
      businesses to manage social media. Lately I've worked on the parts of
      Buffer that let developers and agents build on top of it: an
      auto-generated CLI for the public API, and Buffer's MCP server, including
      OAuth support so it works with the Claude and ChatGPT marketplaces. Before
      that I shipped the Threads trending topics features, end to end.
    </p>

    <p>
      Before Buffer I spent about four years at
      <a href="https://remote.com/" target="_blank" rel="noopener">Remote</a>,
      most recently as a Senior II engineer. I owned features across the stack.
      Elixir and Phoenix on the backend, React and Next.js on the front. I built
      things like AI-powered resume parsing for their ATS and the contractor
      invoicing system. Earlier I worked at
      <a href="https://hubstaff.com/tasks" target="_blank" rel="noopener">Hubstaff</a>
      on a Rails and React project management tool, and before that on B2B and
      web apps in Panama and remotely, including a stint with X-Team building
      CoinList for Protocol Labs.
    </p>

    <p>
      I studied computer science at
      <a href="https://www.harding.edu/" target="_blank" rel="noopener">Harding University</a>
      in the US, and did an M.Sc. at
      <a href="https://www.uu.se/en" target="_blank" rel="noopener">Uppsala University</a>
      in Sweden. My thesis there was on building AI crawlers for a
      machine-learning system.
    </p>

    <p>
      Outside of work I build my own things.
      <a href="https://www.tonebuilder.ai/" target="_blank" rel="noopener">ToneBuilder</a>
      is an AI tone architect for the Line 6 Helix, solo-built and live.
      <a href="https://www.findmomentum.xyz/" target="_blank" rel="noopener">Momentum</a>
      helps track daily progress through small wins. A few more are on the
      <a href="/products/">products</a> page.
    </p>

    <p>
      I write here about software craftsmanship, building with AI, and the
      occasional dive into CS fundamentals. I work mostly in TypeScript, Elixir,
      and Ruby these days. I play jazz guitar as
      <a href="https://www.youtube.com/diegocasmo" target="_blank" rel="noopener">@diegocasmo</a>.
      Spanish is my first language, and I'm bilingual in English.
    </p>

    <p>
      You can find me on
      <a href="https://github.com/diegocasmo" target="_blank" rel="noopener">GitHub</a>,
      <a href="https://www.linkedin.com/in/diegocasmo/" target="_blank" rel="noopener">LinkedIn</a>,
      and <a href="https://x.com/diegocasmo" target="_blank" rel="noopener">X</a>, or
      read my <a href="/resume.pdf">resume</a>.
    </p>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: 760px;
    margin: 0 auto;
  }
  .page p {
    margin-bottom: 1.2em;
  }
</style>
